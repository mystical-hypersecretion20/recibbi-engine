# ----------------------------------------------------------------------------
# Copy to .env  ->  cp .env.example .env   then fill in what you need.
# Everything has a sensible default; the app runs with an empty .env (it will
# fall back to offline Tesseract OCR and skip enrichment).
# ----------------------------------------------------------------------------

# --- Server ---
PORT=8080
# Public base URL used to build shareable links (Telegram replies, API output).
# Set this to your host's reachable address if not localhost.
PUBLIC_BASE_URL=http://localhost:8080
LOG_LEVEL=info

# --- Multi-tenancy ---
# Every resource is scoped to an identity: a (tenant, user) pair. A resource's
# public id is the composite "<tenant>:<user>:<cacheId>". These defaults are the
# IMPLICIT identity used when a request/CLI omits one, so a single-tenant
# deployment passes nothing and everything lands under main/main.
#   - To run STRICT multi-tenant (require X-Tenant-Id/X-User-Id on every request),
#     set these EMPTY:  DEFAULT_TENANT_ID=
#   - Tenants are provisioned accounts: an upload for an unknown tenant is
#     rejected. Create one with `POST /api/tenants {tenantId}` or
#     `receipts tenant create <id>` (the default tenant is auto-created).
DEFAULT_TENANT_ID=main
DEFAULT_USER_ID=main

# --- Redis / queue --- (inside compose this is set for you to redis://redis:6379)
# REDIS_URL=redis://localhost:6379
QUEUE_CONCURRENCY=2
JOB_ATTEMPTS=3

# --- Persistence layer ---
# Where durable records (receipts, profile definitions, profile + product
# results, tenant registry) are stored. Chosen here, like OCR_PROVIDER — NOT
# per-record. Uploaded image blobs always stay on the filesystem regardless.
#   sqlite     = a single SQLite database file, generic document table (default)
#   filesystem = scope-partitioned JSON files under DATA_DIR (the original approach)
#   postgresql = planned (TODO) — not implemented yet
PERSISTENCE=sqlite
# SQLite database file (only used when PERSISTENCE=sqlite). Defaults under
# DATA_DIR so it shares the data volume.
# SQLITE_PATH=./data/receipt-enricher.db

# --- Receipt extraction ---
# auto = use a vision model if a key is present, otherwise Tesseract OCR.
# Options: auto | vision | tesseract
OCR_PROVIDER=auto

# Which vision model to use when OCR_PROVIDER=vision (or auto with a key set).
# Options: anthropic | openai
VISION_PROVIDER=anthropic

# Anthropic (recommended for receipt extraction quality)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (alternative)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Item enrichment (Tavily) ---
# Without a key, items are still extracted; enrichment (images/metadata) is skipped.
TAVILY_API_KEY=
ENRICH_MAX_ITEMS=40
TAVILY_SEARCH_DEPTH=basic

# --- Product resolution (final stage: line item -> product info) ---
# Maps each cleaned line item from a profile result to a product (title,
# description, substantiating web link) via a configurable backend resolver.
# Runs after a profile is applied; on by default for uploads (opt out per-upload
# with form field resolveProducts=0). Reuses ANTHROPIC_API_KEY above.
PRODUCTS_ENABLED=true
PRODUCT_RESOLVER=anthropic
PRODUCT_ANTHROPIC_MODEL=claude-haiku-4-5
# Ground productUrl via Anthropic's server-side web search. If the model can't
# use web tools, set PRODUCT_ANTHROPIC_MODEL=claude-sonnet-4-6 or this to 0.
PRODUCT_ANTHROPIC_WEB_SEARCH=true
PRODUCT_MAX_ITEMS=100
# Per-item lookups run in a bounded parallel pool, fronted by a shared Redis
# cache (keyed by resolver+store+sku+description) so repeat products across
# receipts/sessions skip the backend call.
PRODUCT_CONCURRENCY=5
PRODUCT_CACHE_ENABLED=true
PRODUCT_CACHE_TTL_SECONDS=2592000
# Per-lookup event buffer feeding the live console at /products/monitor (0 off).
PRODUCT_EVENTS_MAX=500
PRODUCT_RESOLVE_ON_UPLOAD=true

# --- Telegram bot (optional) ---
# Get a token from @BotFather. Start the bot with the "telegram" compose profile.
TELEGRAM_BOT_TOKEN=
# Tenant the bot's uploads belong to (must be provisioned unless it's the server
# default). Empty = use the server default tenant. Each Telegram user is mapped
# to a distinct user id (tg_<telegram-user-id>) within that tenant.
TELEGRAM_TENANT_ID=
